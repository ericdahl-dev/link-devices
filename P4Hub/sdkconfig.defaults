# This P4-NANO is early silicon (chip rev v1.3). ESP-IDF v5.5 defaults its
# minimum P4 revision to v3.01 and refuses to boot; drop it to v1.0. Arduino
# tolerates v1.x natively, but the P4 hub features need ESP-IDF, so this gate is
# required here. See tasks/P4-004.md + the P4-NANO board notes.
CONFIG_ESP32P4_SELECTS_REV_LESS_V3=y
CONFIG_ESP32P4_REV_MIN_100=y

# WiFi is provided by the onboard ESP32-C6 co-processor over ESP-Hosted.
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y

# Larger USB control transfers for MIDI-class config descriptors (P4-003).
CONFIG_USB_HOST_CONTROL_TRANSFER_MAX_SIZE=1024

# 1 kHz tick so the "1 ms" clock_out loop's vTaskDelay(pdMS_TO_TICKS(1)) is a real
# 1-tick yield. At the ESP-IDF default 100 Hz, pdMS_TO_TICKS(1) truncates to 0 →
# the priority-6 clock_out task busy-spins, starving IDLE0 (task-WDT) and adding
# up to 10 ms of MIDI-clock jitter. 1 kHz gives ≤1 ms clock granularity (P4-006).
CONFIG_FREERTOS_HZ=1000

# WiFi credentials (CONFIG_P4HUB_WIFI_*) are intentionally NOT set here — set them
# locally (menuconfig or a gitignored sdkconfig); never commit credentials.

# OTA firmware updates (P4-016): the built-in two-slot table (otadata + ota_0 +
# ota_1, ~1.5 MB each) so `POST /update` can write the inactive slot and boot
# into it via esp_ota_set_boot_partition — no factory partition, both slots are
# equal-purpose OTA targets.
CONFIG_PARTITION_TABLE_TWO_OTA=y
